# ================================
# FastAPI Starter Template Configuration
# ================================
# Copy this file to .env and configure your values

# ================================
# 🏗️ APPLICATION SETTINGS
# ================================
# Environment: development, staging, or production
ENVIRONMENT="development"

# ================================
# 🌐 API SETTINGS
# ================================
# API host and port
API_HOST="127.0.0.1"
API_PORT="8000"

# ================================
# 🔐 SECURITY SETTINGS
# ================================
# API key for external authentication
API_KEY="your-secret-api-key-here"

# Secret key for JWT token generation (CHANGE IN PRODUCTION!)
SECRET_KEY="change-this-secret-key-in-production"

# JWT algorithm
ALGORITHM="HS256"

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES="30"

# ================================
# 🗄️ DATABASE SETTINGS
# ================================
# Database URL (PostgreSQL with psycopg)
# Format: postgresql+psycopg://user:password@host:port/database
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/fastapi_db"

# For SQLite development (uncomment to use):
# DATABASE_URL="sqlite:///./fastapi.db"

# Enable database query logging (true/false)
DATABASE_ECHO="true"

# Database connection pool settings
DATABASE_POOL_SIZE="5"
DATABASE_MAX_OVERFLOW="10"

# ================================
# 🚀 SERVER SETTINGS
# ================================
# Number of uvicorn worker processes
# Production: 4 or more, Development: 1
WORKERS="1"

# Enable auto-reload on code changes (development only)
RELOAD="true"

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="DEBUG"

# ================================
# 📦 REDIS SETTINGS (Optional)
# ================================
# Redis connection URL for caching/sessions
REDIS_URL="redis://localhost:6379/0"

# ================================
# 🌍 CORS SETTINGS
# ================================
# Comma-separated list of allowed origins for CORS
# Example: "http://localhost:3000,https://example.com"
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS="true"

# Allowed HTTP methods (* for all, or comma-separated: GET,POST,PUT,DELETE)
CORS_ALLOW_METHODS="*"

# Allowed headers (* for all, or comma-separated)
CORS_ALLOW_HEADERS="*"
