# ================================
# Telegram Bot "Tebak Kata" Configuration
# ================================
# Copy this file to .env and configure your values

# ================================
# 🏗️ APPLICATION SETTINGS
# ================================
# Environment: development, staging, or production
ENVIRONMENT="" 				# Provide a value for ENVIRONMENT

# ================================
# 🤖 TELEGRAM BOT SETTINGS
# ================================
# Bot token from @BotFather (REQUIRED)
# Get it by messaging @BotFather on Telegram and creating a new bot
BOT_TOKEN="" 				# Provide a value for BOT_TOKEN

# Bot username (optional, for logging)
BOT_USERNAME="" 				# Provide a value for BOT_USERNAME

# Admin usernames (comma-separated, without spaces if possible)
# Example: ADMIN_TELEGRAM_USERNAMES="raihanhd,adminlain"
ADMIN_TELEGRAM_USERNAMES="" 				# Provide a value for ADMIN_TELEGRAM_USERNAMES

# ================================
# 🎮 GAME SETTINGS
# ================================
# Game timeout in seconds
GAME_TIMEOUT="" 				# Provide a value for GAME_TIMEOUT

# Hint penalty per hint (0.5 = 50% penalty)
HINT_PENALTY="" 				# Provide a value for HINT_PENALTY

# Maximum hints allowed per game
MAX_HINTS="" 				# Provide a value for MAX_HINTS

# Maximum number of times a question can be reused
MAX_USED_COUNT="" 				# Provide a value for MAX_USED_COUNT

# ================================
# 🧠 LLM AGENT API SETTINGS (Optional)
# ================================
# LLM Agent API base URL
# Example: "https://agent.admasolusi.space"
LLM_URL="" 				# Provide a value for LLM_URL

# LLM Agent API key (used in x-api-key header)
LLM_HEADER_API_KEY="" 				# Provide a value for LLM_HEADER_API_KEY

# LLM Agent ID (used in /api/v1/agents/{agent_id}/execute endpoint)
LLM_AGENT_ID="" 				# Provide a value for LLM_AGENT_ID

LLM_MODEL_API_KEY="" 				# Provide a value for LLM_MODEL_API_KEY

# Number of questions to generate per refresh
LLM_REFRESH_COUNT="" 				# Provide a value for LLM_REFRESH_COUNT

# Cooldown /refresh per chat (seconds). Set 0 to disable.
LLM_REFRESH_COOLDOWN_SECONDS="" 				# Provide a value for LLM_REFRESH_COOLDOWN_SECONDS

# ================================
# 🗄️ DATABASE SETTINGS
# ================================
# Database URL (PostgreSQL with psycopg)
# Format: postgresql+psycopg://user:password@host:port/database
DATABASE_URL="" 				# Provide a value for DATABASE_URL

# For SQLite development (uncomment to use):
# DATABASE_URL="sqlite:///./tebak_kata.db"

# Enable database query logging (true/false)
DATABASE_ECHO="" 				# Provide a value for DATABASE_ECHO

# Database connection pool settings
DATABASE_POOL_SIZE="" 				# Provide a value for DATABASE_POOL_SIZE
DATABASE_MAX_OVERFLOW="" 				# Provide a value for DATABASE_MAX_OVERFLOW

# ================================
# 🚀 SERVER SETTINGS
# ================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="" 				# Provide a value for LOG_LEVEL

# ================================
# 📦 REDIS SETTINGS (Optional - not used currently)
# ================================
# Redis connection URL for caching/sessions
REDIS_URL="" 				# Provide a value for REDIS_URL
